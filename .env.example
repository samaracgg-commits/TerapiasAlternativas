# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Credentials Override (for custom projects like "Clinicaterapias")
# Configure these variables in AI Studio Settings > Secrets or in your local .env file.
# You can find these values under Project Settings in your Firebase Console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID="clinicaterapias-23ef8"
VITE_FIREBASE_AUTH_DOMAIN="clinicaterapias-23ef8.firebaseapp.com"
VITE_FIREBASE_DATABASE_ID="(default)"
VITE_FIREBASE_STORAGE_BUCKET="clinicaterapias-23ef8.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
